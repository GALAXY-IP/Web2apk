# =============================================
# AXKA BUILDER - Environment Variables
# Copy file ini ke .env dan sesuaikan isinya
# =============================================

# Server
PORT=3000
NODE_ENV=production

# JWT Secret - WAJIB diganti dengan string random panjang
JWT_SECRET=ganti_dengan_string_random_panjang_minimal_32_karakter

# =============================================
# Admin credentials (default, bisa diubah via app.py)
# Username: AXKA
# Password: Asiafone11
# =============================================

# =============================================
# FIREBASE (Opsional - untuk real-time chat & Google Login)
# Buat project di: https://console.firebase.google.com
# Jika tidak diisi, chat akan pakai polling API (tetap berjalan)
# =============================================
# FIREBASE_PROJECT_ID=databasekey-89582
# FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}  # JSON key service account

# =============================================
# BUILD APK
# =============================================
LOCAL_BUILD=true
# EXTERNAL_BUILD_API=https://appbuilder.rfproject.my.id/
# EXTERNAL_BUILD_KEY=rfapi_4d2f5f135c7b60b27d6b511f95df04cf

# =============================================
# OPENROUTER API KEYS (7 key, fallback otomatis)
# Daftar di: https://openrouter.ai
# =============================================


# =============================================
# BATAS HARIAN PER USER
# =============================================
LIMIT_FREE=5
LIMIT_PRO=80
# ProMax = unlimited

# AI Limit: Free=10/2jam, Pro=80/2jam, ProMax=unlimited

# =============================================
# API KEYS FITUR OPTIONAL
# =============================================
# REMOVEBG_API_KEY=your_removebg_api_key    # https://www.remove.bg/api
# YTDLP_PATH=yt-dlp                         # Path ke yt-dlp binary

# Upload size limits (MB)
MAX_APK_SIZE_MB=150
MAX_HTML_SIZE_MB=50
MAX_IMAGE_SIZE_MB=10
